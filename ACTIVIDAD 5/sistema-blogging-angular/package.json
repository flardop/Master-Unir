{
  "name": "sistema-blogging-angular",
  "version": "0.0.0",
  "scripts": {
    "ng": "/opt/homebrew/opt/node@24/bin/node ./node_modules/@angular/cli/bin/ng",
    "start": "NG_BUILD_PARALLEL_TS=0 NG_BUILD_MAX_WORKERS=1 /opt/homebrew/opt/node@24/bin/node ./node_modules/@angular/cli/bin/ng serve --host 127.0.0.1",
    "build": "NG_BUILD_PARALLEL_TS=0 NG_BUILD_MAX_WORKERS=1 /opt/homebrew/opt/node@24/bin/node ./node_modules/@angular/cli/bin/ng build",
    "watch": "NG_BUILD_PARALLEL_TS=0 NG_BUILD_MAX_WORKERS=1 /opt/homebrew/opt/node@24/bin/node ./node_modules/@angular/cli/bin/ng build --watch --configuration development",
    "test": "NG_BUILD_PARALLEL_TS=0 NG_BUILD_MAX_WORKERS=1 /opt/homebrew/opt/node@24/bin/node ./node_modules/@angular/cli/bin/ng test"
  },
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "dependencies": {
    "@angular/common": "^20.3.0",
    "@angular/compiler": "^20.3.0",
    "@angular/core": "^20.3.0",
    "@angular/forms": "^20.3.0",
    "@angular/platform-browser": "^20.3.0",
    "@angular/router": "^20.3.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular/build": "^20.3.31",
    "@angular/cli": "^20.3.31",
    "@angular/compiler-cli": "^20.3.0",
    "@types/jasmine": "~5.1.0",
    "jasmine-core": "~5.9.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "prettier": "^3.6.2",
    "typescript": "~5.9.2"
  }
}
